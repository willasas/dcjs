{
  "name": "dcjs",
  "version": "1.0.0",
  "description": "a js tools for webdevelopment",
  "keywords": [
    "js",
    "utils",
    "functions",
    "file",
    "browser",
    "cookies"
  ],
  "source": "src/index.js",
  "main": "dist/dc.js",
  "directories": {
    "lib": "dist"
  },
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:rollup": "rollup -c",
    "build:site": "vite build && powershell -ExecutionPolicy Bypass -File copy-files.ps1",
    "test": "jest test/all-tools.test.js",
    "testdom": "jest",
    "test:all": "jest test/all-tools.test.js && node test/test.js | tap-spec",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "jest": {
    "testEnvironment": "jest-environment-jsdom"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@rollup/plugin-terser": "^0.4.4",
    "autoprefixer": "^10.4.24",
    "download": "^8.0.0",
    "fs-extra": "^10.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "live-server": "^1.2.1",
    "postcss": "^8.5.6",
    "rollup": "^2.79.2",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vue": "^3.5.27"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18"
  }
